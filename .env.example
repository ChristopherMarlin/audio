# Copy this file to .env and fill in real values. NEVER commit your real .env file.

# Server
PORT=3000
NODE_ENV=production
# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# Public base URL of the site (used for Stripe redirect URLs, etc.)
PUBLIC_BASE_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys) - use TEST keys until you're ready to go live
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
# From https://dashboard.stripe.com/webhooks after creating an endpoint for /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# Currency for all prices (ISO 4217 lowercase, USD is the standard currency for Curacao tourism business)
CURRENCY=usd

# Bootstrap admin account (only used the first time you run `npm run create-admin`)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-immediately
